# Copy this file to `.env` before local smoke testing.
# Example:
#   cp .env.example .env

# =========================
# Required for smoke test
# =========================

# Discord bot token used by `PYTHONPATH=src python -m bot.app`
DISCORD_BOT_TOKEN=your_bot_token_here

# Test Discord server (guild) ID used for fast slash command sync
DISCORD_GUILD_ID=123456789012345678

# Briefing channel ID used for publish logs and default brief routing
DISCORD_BRIEF_CHANNEL_ID=123456789012345679

# Webhook URL used by `/admin publish` and `scripts/publish_daily.py`
# Replace the placeholders with a real Discord channel webhook URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<CHANNEL_ID>/<WEBHOOK_TOKEN>

# Local SQLite database path for smoke test
DATABASE_URL=sqlite:///./data/app.db

# App mode and log level
APP_ENV=development
LOG_LEVEL=INFO

# =========================
# Optional / future use
# =========================

# Optional admin-only channel if you later split admin traffic
DISCORD_ADMIN_CHANNEL_ID=

# Optional provider keys for future content generation workflows
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
